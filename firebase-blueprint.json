{
  "entities": {
    "profile": {
      "title": "User Profile",
      "description": "Basic information about the user for AI context",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "string" },
        "education": { "type": "string" },
        "linkedin": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "application": {
      "title": "Job Application",
      "description": "Details of a specific job application",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "jobDescription": { "type": "string" },
        "matchScore": { "type": "number" },
        "matchReason": { "type": "string" },
        "coverLetter": { "type": "string" },
        "resumeBullets": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Applied", "Interview", "Offer", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["company", "role", "matchScore"]
    }
  },
  "firestore": {
    "users/{userId}/profile/data": {
      "schema": "profile",
      "description": "User profile data"
    },
    "users/{userId}/applications/{applicationId}": {
      "schema": "application",
      "description": "A job application entry"
    }
  }
}
